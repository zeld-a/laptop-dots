{
  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "icon_theme": "Warm Charmed Icons",

  "ui_font_family": "Google Sans",
  "ui_font_size": 16,

  "terminal": {
    "font_family": "Google Sans Code",
    "font_size": 16,
    "scrollbar": {
      "show": "never",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
  },

  "buffer_font_family": "Google Sans Code",
  "buffer_font_size": 16,
  "buffer_line_height": "standard",
  "cursor_shape": "block",
  "cursor_blink": false,
  "selection_highlight": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "auto_indent_on_paste": false,
  "show_completions_on_input": false,
  "hover_popover_enabled": true,
  "format_on_save": "off",
  "extend_comment_on_newline": false,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_startup": "launchpad",
  "session": {
    "restore_unsaved_buffers": true,
  },
  "git": {
    "git_gutter": "hide",
  },

  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,

  "theme": "Syntax",

  "title_bar": {
    "show_branch_name": false,
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_project_items": false,
    "show_user_picture": false,
    "show_branch_icon": false,
    "show_menus": false,
  },

  "tab_bar": {
    "show": false,
  },

  "toolbar": {
    "quick_actions": false,
  },

  "status_bar": {
    "experimental.show": false,
  },

  "project_panel": {
    "dock": "right",
    "default_width": 250,
    "hide_root": true,
    "auto_fold_dirs": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },

  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  
  "file_finder": {
    "modal_max_width": "large",
  },

  "scrollbar": {
    "show": "never",
  },

  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
    "breakpoints": false,
  },

  "indent_guides": {
    "enabled": false,
  },

  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
}
